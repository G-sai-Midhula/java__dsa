class WrapperExample {
    public static void main(String args[]) {

        int a = 10;              // primitive type
        Integer obj = Integer.valueOf(a); // converting to object

        System.out.println("Primitive value: " + a);
        System.out.println("Wrapper object: " + obj);
    }
}

//AUTOBOXING[PRIMITIVE---->>OBJECT]
class AutoboxingExample {
    public static void main(String args[]) {

        int a = 20;
        Integer obj = a;   // autoboxing

        System.out.println(obj);
    }
}

//UNBOXING[OBJECT--->PRIMITIVE]


class UnboxingExample {
    public static void main(String args[]) {

        Integer obj = 30;
        int a = obj;  // unboxing

        System.out.println(a);
    }
}


class Laptop {
    public static void main(String args[]) {

        int price = 60000;

        Integer obj = price;  // autoboxing

        int value = obj;      // unboxing

        System.out.println("Wrapper value: " + obj);
        System.out.println("Primitive value: " + value);
    }
}
